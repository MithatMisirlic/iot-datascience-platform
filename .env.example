# SQLite development database. PostgreSQL can use a SQLAlchemy URL later.
DATABASE_URL=sqlite:///./data/experiment_platform.db

# Local recording-artifact storage. Must not be a filesystem root.
UPLOAD_DIR=./data/uploads

# Raw numeric frames used by the development processing workflow.
RAW_FRAME_DIR=./data/exercises

# Runtime behavior
TESTING_MODE=false
LOG_LEVEL=INFO

# Only noop is supported until a Raspberry Pi adapter is implemented.
PI_ADAPTER_MODE=noop

# Comma-separated browser origins allowed by CORS.
CORS_ORIGINS=http://localhost:3000,http://localhost:8501
