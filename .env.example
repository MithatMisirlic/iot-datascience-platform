# Application
APP_NAME=Experiment Platform
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
API_V1_PREFIX=/api/v1

# Database: local SQLite only. PostgreSQL configuration will be added later.
DATABASE_URL=sqlite:///./data/experiment_platform.db

# Storage
UPLOAD_DIR=./data/uploads
RECORDING_DIR=./data/recordings
MAX_UPLOAD_SIZE_MB=100

# Logging
LOG_LEVEL=INFO
LOG_DIR=./data/logs

# Frontend
BACKEND_API_URL=http://127.0.0.1:8000

# Raspberry Pi client
PI_DEVICE_ID=pi-zero-development
PI_API_BASE_URL=http://127.0.0.1:8000/api/v1
PI_RECORDING_DIR=./recordings
PI_REQUEST_TIMEOUT_SECONDS=30

# Browser clients allowed to call the backend (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8501
