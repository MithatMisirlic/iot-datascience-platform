PI_WS_HOST=192.168.0.182
PI_WS_PORT=8080
PI_WS_PATH=/stream

PI_IMU_ENABLED=true
PI_AUDIO_ENABLED=true
PI_CAMERA_ENABLED=false
PI_MOCK_MODE=false

PI_IMU_RATE_HZ=60
PI_AUDIO_RATE_HZ=60
PI_CAMERA_FPS=5

PI_RECONNECT_INITIAL_SECONDS=1
PI_RECONNECT_MAX_SECONDS=30

PI_I2C_BUS=1
PI_MPU6050_ADDRESS=0x68
PI_AUDIO_SAMPLE_RATE=48000
PI_CAMERA_INDEX=0
PI_CAMERA_JPEG_QUALITY=80
PI_WAV_DIR=./recordings
